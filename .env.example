# Preset selector: education | restaurant | dental | salon | gym
VITE_PRESET=education

# Formspree adapter
VITE_FORMSPREE_ENDPOINT=

# EmailJS adapter
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Custom endpoint adapter
VITE_CUSTOM_FORM_ENDPOINT=

# Optional AI news recorder settings
AI_NEWS_QUERY=AI OR "artificial intelligence" OR ChatGPT OR OpenAI OR Anthropic OR Gemini when:7d
AI_NEWS_LIMIT=5
AI_NEWS_PREFERRED_SOURCES=Reuters,The Verge,TechCrunch,MIT Technology Review,The Information
AI_NEWS_MAX_PER_SOURCE=1
AI_NEWS_LANGUAGE=en-US
AI_NEWS_REGION=US
AI_NEWS_OUTPUT_DIR=content/ai-news
AI_CONTENT_VOICE=creator

# Optional Telegram notification
AI_TELEGRAM_BOT_TOKEN=
AI_TELEGRAM_CHAT_ID=
AI_TELEGRAM_SILENT=false
AI_TELEGRAM_REPO_URL=
AI_TELEGRAM_REPO_BRANCH=main
